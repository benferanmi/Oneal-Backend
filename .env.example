NODE_ENV=development
PORT=4000

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

MONGODB_URI=mongodb://localhost:27017/oneals

# Email
# EMAIL_TRANSPORT options: gmail | mailgun | resend
EMAIL_TRANSPORT=gmail
EMAIL_FROM=noreply@onealsdetailing.com
EMAIL_FROM_NAME=O'Neal's Auto Detailing
OWNER_NOTIFICATION_EMAIL=owner@onealsdetailing.com

# Gmail (EMAIL_TRANSPORT=gmail)
EMAIL_USER=
EMAIL_PASS=

# Mailgun SMTP (EMAIL_TRANSPORT=mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# Resend SMTP (EMAIL_TRANSPORT=resend)
RESEND_API_KEY=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS (comma separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Seed admin
SEED_ADMIN_EMAIL=owner@onealsdetailing.com
SEED_ADMIN_PASSWORD=changeme123
SEED_ADMIN_NAME=Owner
